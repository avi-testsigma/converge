    "test": "vitest run"
  },
  "dependencies": {
    "@converge/shared": "workspace:*",
    "@converge/core": "workspace:*",
    "@converge/bt-bridge": "workspace:*"
  },
  "peerDependencies": {
    "storybook": "^8.0.0"
  }
}
